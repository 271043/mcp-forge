{
  "name": "@sharpbits/create-mcp-server",
  "version": "0.1.0",
  "description": "CLI scaffolding tool for MCP (Model Context Protocol) server projects",
  "type": "module",
  "bin": {
    "create-mcp-server": "./bin/create-mcp-server.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --outDir dist --no-splitting",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "scaffolding",
    "create",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/271043/mcp-create-server#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/271043/mcp-create-server.git"
  },
  "bugs": {
    "url": "https://github.com/271043/mcp-create-server/issues"
  }
}
